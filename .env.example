# Copy this file to .env and fill in all values before running.
# Never commit .env to version control.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Local:  postgresql://postgres:postgres@localhost:5432/credit_risk
# Docker: postgresql://postgres:postgres@postgres:5432/credit_risk
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/credit_risk

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local:  redis://localhost:6379/0
# Docker: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# ── MLflow ────────────────────────────────────────────────────────────────────
# Local:  http://localhost:5000
# Docker: http://mlflow:5000
MLFLOW_TRACKING_URI=http://localhost:5000

# ── API auth ──────────────────────────────────────────────────────────────────
# Replace with a strong random secret in production (e.g. openssl rand -hex 32)
API_SECRET_KEY=

# ── Monitoring alerts ─────────────────────────────────────────────────────────
# Slack incoming webhook URL or PagerDuty events API URL
ALERT_WEBHOOK_URL=
